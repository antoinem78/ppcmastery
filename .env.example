# Environment variables — TEMPLATE (committed; no real values here).
# Copy this file to .env.local and fill in the real values there.
# .env.local is gitignored and never leaves your machine.
#
# The same app is deployed ONCE PER ENTITY (e.g. BJ PPC → USD, WMI → GBP):
# one repo, multiple Vercel projects, each with its own copy of these vars.
# Code never branches on entity — it only reads this config (src/lib/config.ts).

# --- Entity / brand (per deployment) ---
# Legal entity behind this deployment, e.g. "BJ PPC sp. z o.o. trading as PPC Mastery".
ENTITY_LEGAL_NAME=
# Brand shown in the UI (wordmark, titles, wizard header).
BRAND_NAME=
# Optional logo image URL; empty = text wordmark.
BRAND_LOGO_URL=
# ISO 4217 currency for all prices: USD for BJ PPC, GBP for WMI.
CURRENCY=
# VAT percentage + number — used on quotes/invoices from Phase 2.
VAT_RATE=
VAT_NUMBER=

# --- Stripe (per deployment — each entity has its own Stripe account) ---
# TEST mode keys until the loop is proven; live keys only after.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PandaDoc (contract provider for this deployment) ---
PANDADOC_API_KEY=

# --- Supabase (server-side only; the Next.js backend uses these) ---
# From Supabase → Project Settings → API Keys (the "Publishable and secret" tab).
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# --- Auth0 (login) ---
# Domain + Client ID from Auth0 → Applications → your app → Settings.
# Client Secret from the same page (sensitive). AUTH0_SECRET is a 32-byte hex
# string for cookie encryption: generate with `openssl rand -hex 32`.
# APP_BASE_URL is this app's own URL (http://localhost:3000 locally;
# https://ppcmastery.vercel.app in production).
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=
